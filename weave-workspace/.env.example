TF_VAR_docker_network_name=weave_network

TF_VAR_tenant_domain=weave.local
# Enable only for local integration testing.
# TF_VAR_create_test_user=true
TF_VAR_auth_subdomain=auth
TF_VAR_api_subdomain=api
TF_VAR_nextcloud_subdomain=files
TF_VAR_matrix_subdomain=matrix

TF_VAR_public_scheme=https

# Canonical single-stack ports.
# Use these only on a machine where Weave owns the standard local ports.
# TF_VAR_proxy_http_host_port=80
# TF_VAR_proxy_host_port=443
# TF_VAR_keycloak_host_port=8080
# TF_VAR_keycloak_management_host_port=9000
# TF_VAR_mas_host_port=8082
# TF_VAR_synapse_host_port=8008
# TF_VAR_nextcloud_host_port=8083
# TF_VAR_backend_host_port=8084

# Required shared-host isolation block.
# install.sh defaults to this block so Weave does not collide with another local stack.
TF_VAR_proxy_http_host_port=44080
TF_VAR_proxy_host_port=44443
TF_VAR_keycloak_host_port=48080
TF_VAR_keycloak_management_host_port=49000
TF_VAR_mas_host_port=48082
TF_VAR_synapse_host_port=48008
TF_VAR_nextcloud_host_port=48083
TF_VAR_backend_host_port=48084

TF_VAR_nextcloud_trusted_proxies=172.16.0.0/12
TF_VAR_api_upstream=weave-backend:8080

TF_VAR_proxy_image=caddy:2.8

# Leave these unset for install.sh defaults, or set absolute paths.
# TF_VAR_caddy_tls_cert_file=/absolute/path/to/weave-workspace/01-infrastructure/.generated/caddy/certs/weave.local.pem
# TF_VAR_caddy_tls_key_file=/absolute/path/to/weave-workspace/01-infrastructure/.generated/caddy/certs/weave.local-key.pem
# TF_VAR_caddy_tls_ca_file=/absolute/path/to/weave-workspace/01-infrastructure/.generated/caddy/certs/weave-local-ca.pem

# Optional runner-hygiene toggles for self-hosted CI or any shared Docker host.
# WEAVE_RUNNER_HYGIENE=true
# WEAVE_REMOVE_VOLUMES=true

WEAVE_CADDY_CONTAINER_NAME=weave-proxy
WEAVE_CADDYFILE_PATH=./01-infrastructure/.generated/caddy/Caddyfile
WEAVE_CADDY_CERTS_DIR=./01-infrastructure/.generated/caddy/certs
