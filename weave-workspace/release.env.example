# Copy this file to a private, untracked env file before a real deployment.
# Replace every placeholder value.
# Keep the real file chmod 600 and track rotation dates outside git.

TF_VAR_docker_network_name=weave_network

TF_VAR_tenant_slug=weave
TF_VAR_tenant_domain=weave.example
TF_VAR_auth_subdomain=auth
TF_VAR_matrix_subdomain=matrix
TF_VAR_nextcloud_subdomain=files
TF_VAR_api_subdomain=api

TF_VAR_public_scheme=https
TF_VAR_proxy_http_host_port=80
TF_VAR_proxy_host_port=443

# Stage publicly trusted TLS material on the host and point these at absolute paths.
TF_VAR_caddy_tls_cert_file=/opt/weave/tls/weave.example.pem
TF_VAR_caddy_tls_key_file=/opt/weave/tls/weave.example-key.pem
# Leave unset unless clients must trust a private CA.
# TF_VAR_caddy_tls_ca_file=/opt/weave/tls/private-ca.pem

# Pin a release image or digest, do not use :latest for production.
TF_VAR_weave_backend_image=ghcr.io/masssi164/weave-backend:release-1

# Release deployments should keep the local test user flow disabled.
TF_VAR_create_test_user=false

TF_VAR_db_name=weave
TF_VAR_db_admin_username=weave_admin
TF_VAR_db_admin_password=replace-me

TF_VAR_keycloak_admin_username=admin
TF_VAR_keycloak_admin_password=replace-me
TF_VAR_keycloak_db_username=keycloak
TF_VAR_keycloak_db_password=replace-me

TF_VAR_mas_db_username=mas
TF_VAR_mas_db_password=replace-me
TF_VAR_synapse_db_username=synapse
TF_VAR_synapse_db_password=replace-me
TF_VAR_nextcloud_db_username=nextcloud
TF_VAR_nextcloud_db_password=replace-me

TF_VAR_nextcloud_admin_username=admin
TF_VAR_nextcloud_admin_password=replace-me

TF_VAR_matrix_mas_client_secret=replace-me
TF_VAR_mas_encryption_secret=replace-me
TF_VAR_mas_signing_key_pem='-----BEGIN PRIVATE KEY-----
replace-me
-----END PRIVATE KEY-----'
TF_VAR_mas_matrix_secret=replace-me
TF_VAR_synapse_registration_shared_secret=replace-me
TF_VAR_synapse_macaroon_secret_key=replace-me
TF_VAR_synapse_form_secret=replace-me

# Optional when you do not use the Terraform defaults.
# TF_VAR_nextcloud_trusted_proxies=10.0.0.0/8
# TF_VAR_backend_host_port=8084
# TF_VAR_backend_container_port=8080
# TF_VAR_synapse_uid=991
# TF_VAR_synapse_gid=991

# Public verification inputs for release-verify.sh and operator-check.sh.
WEAVE_BASE_URL=https://api.weave.example
WEAVE_OIDC_ISSUER_URL=https://auth.weave.example/realms/weave
WEAVE_NEXTCLOUD_URL=https://files.weave.example
WEAVE_MATRIX_URL=https://matrix.weave.example
# WEAVE_TLS_CA_FILE=/opt/weave/tls/private-ca.pem
